{
  "name": "playwright-ai-triage",
  "version": "0.6.0",
  "description": "Playwright reporter that classifies test failures with an LLM (real bug / flaky / selector drift / environment issue) and posts a readable summary to stdout, a GitHub PR comment, or Slack.",
  "keywords": [
    "playwright",
    "reporter",
    "testing",
    "triage",
    "flaky-tests",
    "ci",
    "ai",
    "claude"
  ],
  "license": "MIT",
  "author": "Yaroslav Krivushenko",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/flaketrace/playwright-ai-triage.git"
  },
  "type": "module",
  "engines": {
    "node": ">=18"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "vitest run",
    "gate": "npm run lint && npm run typecheck && npm run test && npm run build",
    "prepublishOnly": "npm run gate",
    "release": "npm run build && changeset publish",
    "eval:smoke": "tsx eval/run.ts"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.40.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "eslint": "^9.39.5",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "zod": "^4.4.3"
  }
}
