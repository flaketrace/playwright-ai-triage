.eslintcache

# local environment & OS noise
.env*
.DS_Store

# Agentic flow — the governed layer (.agentic contracts + .claude agents/hooks) is
# TRACKED: it is the single source of truth for how agents work in this repo, and a
# fresh clone or worktree must get it from git. Only runtime state and confidential
# machine-local files stay out.
.claude/worktrees/
.claude/hooks/leak_patterns.txt
.claude/hooks/__pycache__/
.github/scripts/__pycache__/
.claude/.review-stamp
.claude/checkpoints/
.claude/settings.local.json
.agentic/state/
.agentic/agentic-os/install.json
.agentic/agentic-os/doctor.json

# internal development tooling — intentionally untracked in this repo
.agents/
.ai-run/
.cursor/
.codex/
.serena/
# anchored to root: unanchored names also swallow same-named files at any depth
# (case-insensitively on macOS — this silently excluded a tracked guide once)
/CLAUDE.md
/AGENTS.md
/PATTERNS.md
/ARCHITECTURE.md
/SYNC_TO_WIKI.md
docs/audits/
docs/superpowers/
.githooks/
scripts/install-git-hooks.sh

# local eval harness / grader tooling + scratch artifacts — never committed
.eval-scratch/
scratch/
